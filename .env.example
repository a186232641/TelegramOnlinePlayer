# 复制为 .env 后填写(.env 已被 .gitignore 忽略,切勿提交)。
#   cp .env.example .env

# ---- Telegram MTProto 凭据(my.telegram.org 申请) ----
TG_API_ID=
TG_API_HASH=

# ---- backend↔broker 共享密钥(随机 24+ 字节十六进制) ----
#   生成示例:openssl rand -hex 24
BROKER_INTERNAL_TOKEN=

# ---- 访问密码哈希(bcrypt) ----
#   生成:docker compose run --rm backend hash-password
#   或本地:go run ./cmd/app hash-password
ACCESS_PASSWORD_HASH=

# ---- 会话与播放 URL 签名密钥(各 32+ 字节,独立) ----
#   生成示例:openssl rand -hex 32
SESSION_SECRET=
PLAY_URL_SECRET=

# ---- 数据库 ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=recordings

# ---- 其它(均有默认值,可不填) ----
# 外网必须经 HTTPS;纯 HTTP 调试时设 false,否则 Secure cookie 不会被浏览器保存
COOKIE_SECURE=true
# 宿主机映射端口
BACKEND_PORT=8080
# 文件名时间戳假定时区
MEDIA_TIMEZONE=Asia/Shanghai
# 缓存容量上限(字节,含下载/转码临时区),默认 20 GiB
CACHE_MAX_BYTES=21474836480
# ffmpeg 转码并发上限
TRANSCODE_CONCURRENCY=1
# broker 对 Telegram 的限速
BROKER_RPS=2
BROKER_MAX_CONCURRENT=1
